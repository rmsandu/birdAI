GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
EBIRD_API_KEY=your_ebird_api_key_here

BIRDAI_LOCATION=Zurich, Switzerland
# Optional default coordinates for the UI:
# BIRDAI_DEFAULT_LATITUDE=47.3769
# BIRDAI_DEFAULT_LONGITUDE=8.5417

# Optional overrides:
# EBIRD_LOOKBACK_DAYS=30
# EBIRD_RADIUS_KM=25
# EBIRD_MAX_RESULTS=10
# BIRDAI_HTTP_TIMEOUT_SECONDS=20
# BIRDAI_GEOCODING_URL=https://nominatim.openstreetmap.org/search
# BIRDAI_GEOCODING_USER_AGENT=BirdAI/0.1
